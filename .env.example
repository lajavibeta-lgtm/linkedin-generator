# ============================================================================
# VARIABLES DE ENTORNO - LinkedIn Generator
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. NUNCA commits el archivo .env a control de versiones
#
# ============================================================================

# GROQ API KEY
# ============================================================================
# Clave de API para acceder a modelos de Groq (llama-3.3-70b-versatile)
#
# Cómo obtenerla:
# 1. Visita: https://console.groq.com
# 2. Inicia sesión con tu cuenta de Groq
# 3. Ve a "API Keys" en el panel de control
# 4. Haz clic en "Create New API Key"
# 5. Copia la clave generada (comienza con "gsk_")
#
# Ejemplo: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINKEDIN OAUTH
# ============================================================================
# Credenciales de la app de LinkedIn para el flujo OAuth 2.0
#
# Cómo obtenerlas:
# 1. Visita: https://www.linkedin.com/developers/apps
# 2. Crea una app o selecciona la existente
# 3. En "Auth" copia el Client ID y Client Secret
# 4. Agrega el Redirect URI: https://tu-app.vercel.app/api/linkedin-callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# CORS - Dominio permitido para llamadas a la API
# ============================================================================
# En producción: tu dominio de Vercel o dominio propio
# Si no se define, la API acepta cualquier origen (solo para desarrollo local)
#
# Ejemplo: https://linkedin-generator.vercel.app
ALLOWED_ORIGIN=https://your-app.vercel.app

# ============================================================================
# NOTAS ADICIONALES
# ============================================================================
# - Los tokens y claves son sensibles: no los compartas ni subas a repositorios
# - Para cambiar valores, edita .env (no .env.example)
# - En Vercel: agrega GROQ_API_KEY, LINKEDIN_CLIENT_ID, LINKEDIN_CLIENT_SECRET
#   y ALLOWED_ORIGIN en Settings → Environment Variables
